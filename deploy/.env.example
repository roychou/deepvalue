# Tedium Premium deploy secrets — copy to deploy/.env (gitignored) on the VPS.
#
# The ONLY secret on disk is a read-only Doppler service token; `doppler run` (in both
# entrypoints) fetches the real secrets at runtime and injects them as env, never to disk.
# Reuse parley's Doppler token — its config already holds TWS creds (same DU paper account),
# EDGAR_USER_AGENT, ANTHROPIC_API_KEY, and SMTP_*/TELEGRAM_*.
DOPPLER_TOKEN=dp.st.prd.xxxxxxxxxxxxxxxxxxxx

# Optional: container timezone (schedule is US-market-relative). Default America/New_York.
TZ=America/New_York
